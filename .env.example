# Google Calendar integration for the reservation form (see src/lib/google-calendar.ts).
# Copy this file to .env.local and fill in the values from your Google Cloud service account.

# The email address of the Google Cloud service account (ends in @<project>.iam.gserviceaccount.com).
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# The service account's private key, from the downloaded JSON key file's "private_key" field.
# Paste it exactly as-is, including "-----BEGIN PRIVATE KEY-----" / "-----END PRIVATE KEY-----" and \n line breaks.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# The calendar to add reservations to. Usually the restaurant's Gmail address
# (its primary calendar), or a dedicated calendar's ID from Google Calendar settings.
GOOGLE_CALENDAR_ID=

# Max number of guests the restaurant can seat at once for online bookings.
# Defaults to 30 if not set. Confirm the real number with the client.
RESERVATION_MAX_GUESTS_PER_SLOT=30
